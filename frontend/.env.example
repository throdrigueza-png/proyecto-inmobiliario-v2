# Copy this file to .env.local and fill in your values.
# The .env.local file is git-ignored and must NEVER be committed.
# In Azure Static Web Apps, set these as GitHub repository secrets so they are
# injected at build time by GitHub Actions (Settings → Secrets → Actions).

# Full URL of the backend API (Azure App Service URL, no trailing slash).
# Example: https://your-api-name.azurewebsites.net
VITE_API_URL=

# Google OAuth 2.0 client ID — required for the "Continuar con Google" button.
# Obtain from https://console.cloud.google.com/ → APIs & Services → Credentials.
VITE_GOOGLE_CLIENT_ID=

# WhatsApp phone number for the contact button (country code + number, no +).
# Colombia: country code 57 + 10-digit mobile number. Example: 573105597895
VITE_MONICA_PHONE=

# Social media URLs shown in the hero section.
VITE_FACEBOOK_URL=
VITE_INSTAGRAM_URL=
