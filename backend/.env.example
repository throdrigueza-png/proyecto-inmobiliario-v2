# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must NEVER be committed.

# PostgreSQL connection string (Azure or local)
# If the password contains special characters (e.g. @), percent-encode them
# (@ → %40).  Example for Azure Database for PostgreSQL:
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# JWT secret — use a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Google OAuth client ID (optional — only needed for Google login)
GOOGLE_CLIENT_ID=

# Cloudinary credentials — needed for image uploads.
# Create a free account at https://cloudinary.com and copy the values from
# your Dashboard > Account Details.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini API key (optional — only needed for AI-powered features)
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Set to "true" ONLY when initialising a brand-new / empty database.
# After the first successful startup, delete or set to "false" to avoid
# accidentally wiping all data on every restart.
RECREATE_TABLES=false
